@model TriangleAreaSolver // This line specifies that the model for this view is of type TriangleAreaSolver, which will be used to bind data and perform operations related to solving the area of a triangle.
<h1>Welcome to the Triangle Area Solver</h1>

<div asp-validation-summary="All"></div>
<form asp-action="index" method="post">
    <div>
        <label for="sideA">Side A:</label>
        <input type="number" asp-for="Base" step="any" /> @*This creates an input field *@
        <br />
        <label for="sideB">Side B:</label>
        <input type="number" asp-for="Height" step="any" /> @*This creates an input field*@
        <br />
        <button type="submit">Calculate Triangle Area</button>
        <br />
        <label>Hypotenuse:</label>
        <input value="@ViewBag.Hypotenuse?.ToString()" readonly /> @*This creates an input field *@

        
        
    </div>
</form>
